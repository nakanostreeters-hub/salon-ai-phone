# ============================================
# salon-ai-phone 環境変数テンプレート
# ============================================
# ローカル開発時: このファイルを .env にコピーして値を埋める
# Renderデプロイ時: Render Dashboard の Environment で個別設定
# ============================================

# --- 基本設定 ---
PORT=3000
NODE_ENV=development
BASE_URL=https://your-ngrok-url.ngrok.io

# --- マルチサロン分離（必須） ---
# 全DB書き込みに salon_id として付与される。RLSのテナント分離キー。
SALON_ID=premier-models
# 機微情報の暗号化に使用（32文字以上のランダム文字列を生成）
# 例: openssl rand -base64 48
ENCRYPTION_KEY=your-encryption-key-here

# --- Claude AI（必須） ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Supabase（必須） ---
SUPABASE_URL=https://tnplbtnogklqpogdzdmk.supabase.co
SUPABASE_ANON_KEY=（Supabase管理画面のSettings→APIから取得）

# --- LINE連携（AIカウンセリング中継・必須） ---
LINE_CHANNEL_ID=（LINE DevelopersのChannel ID）
LINE_CHANNEL_SECRET=（LINE DevelopersのChannel Secret）
LINE_CHANNEL_ACCESS_TOKEN=（LINE DevelopersのChannel Access Token）
KARUTEKUN_WEBHOOK_URL=https://line-webhook.karutekun.com/webhook/salons/227

# --- Slack連携（必須） ---
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SLACK_CHANNEL_ID=C0AL35N4Y06

# --- Slack 担当チャンネル（オプション） ---
SLACK_CHANNEL_ALL=
SLACK_CHANNEL_NEW=
SLACK_CH_KAJIWARA=
SLACK_CH_MORI=
SLACK_CH_OTA=
SLACK_CH_WATANABE=
SLACK_CH_JUN=
SLACK_CH_JACKIE=

# --- Webチャット ---
SALON_NAME=PREMIER MODELS 中野

# --- Tasker (楽天ミニ・ローカル開発時のみ) ---
TASKER_ENDPOINT_URL=http://YOUR_RAKUTEN_MINI_IP:PORT/send-sms

# --- フリーランスモード（テスト用・オプション） ---
FREELANCE_TEST_LINE_CHANNEL_ID=
FREELANCE_TEST_LINE_CHANNEL_SECRET=
FREELANCE_TEST_LINE_CHANNEL_ACCESS_TOKEN=
FREELANCE_NOTIFICATION_EMAIL=

# --- メッセージ設定 ---
VOICE_MESSAGE=お電話ありがとうございます。現在電話に出ることができません。ご用件をお聞きするため、こちらからSMSにてご連絡いたします。
SMS_MESSAGE=お電話ありがとうございます。こちらからSMSにてご連絡いたします。
